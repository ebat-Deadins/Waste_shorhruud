// ── Audio ──────────────────────────────────────────────────────────
let _actx = null;
function act() {
  if (!_actx) _actx = new (window.AudioContext||window.webkitAudioContext)();
  return _actx;
}
function tone(f1,f2,dur,type='square',vol=0.14){
  try{
    const ac=act(), o=ac.createOscillator(), g=ac.createGain();
    o.connect(g); g.connect(ac.destination);
    o.type=type; o.frequency.value=f1;
    if(f2) o.frequency.linearRampToValueAtTime(f2, ac.currentTime+dur*0.6);
    g.gain.setValueAtTime(vol, ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime+dur);
    o.start(); o.stop(ac.currentTime+dur);
  }catch(e){}
}
function sfxPickup(){ tone(480,560,0.08,'square',0.1); }
function sfxDrag(type){
  if(type===HAZARDOUS) tone(120,100,0.12,'sawtooth',0.06);
  else if(type===RECYCLE) tone(380,420,0.08,'square',0.06);
  else tone(260,280,0.08,'triangle',0.06);
}
function sfxDrop(){ tone(300,260,0.12,'square',0.08); }
