<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Хог Ангилах - Монгол</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600;700;900&family=Noto+Sans+Mongolian&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --bg2: #111118;
    --bg3: #1a1a24;
    --surface: #16161f;
    --border: rgba(255,255,255,0.07);
    --text: #e8e8f0;
    --text2: #9090a8;
    --blue: #3b9eff;
    --blue-dark: #1a6fcc;
    --blue-glow: rgba(59,158,255,0.18);
    --green: #2ecc71;
    --green-dark: #1a8a4a;
    --green-glow: rgba(46,204,113,0.18);
    --red: #e74c3c;
    --red-dark: #a12f24;
    --red-glow: rgba(231,76,60,0.18);
    --accent: #f39c12;
    --r: 12px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Exo 2', sans-serif;
    min-height: 100vh;
    overflow-y: auto;
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--blue-dark); border-radius: 3px; }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(10,10,15,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-logo {
    font-size: 1.2rem; font-weight: 900; letter-spacing: 1px;
    background: linear-gradient(135deg, var(--blue), var(--green));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-links { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .nav-links a {
    color: var(--text2); text-decoration: none; font-size: 0.82rem;
    font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase;
    padding: 0.4rem 0.8rem; border-radius: 6px;
    transition: all 0.2s;
  }
  .nav-links a:hover { color: var(--blue); background: var(--blue-glow); }
  .nav-popup-btn {
    background: linear-gradient(135deg, var(--green-dark), var(--blue-dark));
    color: white; border: none; padding: 0.45rem 1rem;
    border-radius: 6px; font-size: 0.78rem; font-weight: 700;
    cursor: pointer; letter-spacing: 0.5px; transition: opacity 0.2s;
  }
  .nav-popup-btn:hover { opacity: 0.85; }

  /* ===== HERO ===== */
  #home {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding-top: 64px;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 40%, rgba(59,158,255,0.1) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 80% 70%, rgba(46,204,113,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 60% 20%, rgba(231,76,60,0.06) 0%, transparent 50%);
  }
  .hero-grid {
    position: absolute; inset: 0; opacity: 0.04;
    background-image: linear-gradient(var(--blue) 1px, transparent 1px),
      linear-gradient(90deg, var(--blue) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-content {
    position: relative; z-index: 1;
    text-align: center; max-width: 800px; padding: 2rem;
  }
  .hero-tag {
    display: inline-block;
    background: var(--blue-glow); border: 1px solid var(--blue);
    color: var(--blue); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    padding: 0.35rem 1rem; border-radius: 50px; margin-bottom: 1.5rem;
    animation: fadeDown 0.6s ease both;
  }
  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900; line-height: 1.05;
    margin-bottom: 1.2rem;
    animation: fadeDown 0.7s 0.1s ease both;
  }
  .hero-title span { background: linear-gradient(135deg, var(--blue), var(--green)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-sub {
    font-size: 1.05rem; color: var(--text2); line-height: 1.7; max-width: 560px; margin: 0 auto 2.5rem;
    animation: fadeDown 0.7s 0.2s ease both;
  }
  .hero-btns {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeDown 0.7s 0.3s ease both;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--blue), var(--blue-dark));
    color: white; border: none; padding: 0.85rem 2rem;
    border-radius: var(--r); font-size: 0.95rem; font-weight: 700;
    cursor: pointer; text-decoration: none; display: inline-block;
    box-shadow: 0 8px 30px rgba(59,158,255,0.3);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(59,158,255,0.45); }
  .btn-secondary {
    background: transparent; color: var(--text); border: 1px solid var(--border);
    padding: 0.85rem 2rem; border-radius: var(--r); font-size: 0.95rem; font-weight: 600;
    cursor: pointer; text-decoration: none; display: inline-block;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--blue); color: var(--blue); }

  .hero-cards {
    display: flex; gap: 1rem; justify-content: center; margin-top: 3rem; flex-wrap: wrap;
    animation: fadeUp 0.8s 0.5s ease both;
  }
  .hero-card {
    padding: 1rem 1.5rem; border-radius: var(--r);
    border: 1px solid; font-weight: 700; font-size: 0.85rem; letter-spacing: 0.5px;
  }
  .hc-blue { border-color: var(--blue); color: var(--blue); background: var(--blue-glow); }
  .hc-green { border-color: var(--green); color: var(--green); background: var(--green-glow); }
  .hc-red { border-color: var(--red); color: var(--red); background: var(--red-glow); }

  /* ===== SECTIONS ===== */
  section { padding: 5rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; color: var(--blue); margin-bottom: 0.8rem;
  }
  .section-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; margin-bottom: 1rem; }
  .section-desc { color: var(--text2); line-height: 1.7; max-width: 600px; margin-bottom: 3rem; }

  /* ===== WASTE CATEGORIES ===== */
  #classification { background: var(--bg2); }
  .waste-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .waste-card {
    background: var(--surface); border-radius: 16px;
    border: 1px solid var(--border); overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .waste-card:hover { transform: translateY(-5px); }
  .wc-blue:hover { box-shadow: 0 20px 60px rgba(59,158,255,0.2); border-color: var(--blue); }
  .wc-green:hover { box-shadow: 0 20px 60px rgba(46,204,113,0.2); border-color: var(--green); }
  .wc-red:hover { box-shadow: 0 20px 60px rgba(231,76,60,0.2); border-color: var(--red); }
  .waste-card-header {
    padding: 1.8rem 1.8rem 1.2rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .wc-icon {
    width: 56px; height: 56px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; flex-shrink: 0;
  }
  .wc-blue .wc-icon { background: var(--blue-glow); }
  .wc-green .wc-icon { background: var(--green-glow); }
  .wc-red .wc-icon { background: var(--red-glow); }
  .waste-card-header h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.25rem; }
  .wc-blue h3 { color: var(--blue); }
  .wc-green h3 { color: var(--green); }
  .wc-red h3 { color: var(--red); }
  .waste-card-header p { font-size: 0.82rem; color: var(--text2); }
  .waste-card-body { padding: 0 1.8rem 1.8rem; }
  .wc-divider { height: 1px; background: var(--border); margin-bottom: 1.2rem; }
  .wc-items { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .wc-items li {
    font-size: 0.85rem; color: var(--text2); padding: 0.4rem 0.7rem;
    border-radius: 6px; display: flex; align-items: flex-start; gap: 0.5rem;
    background: rgba(255,255,255,0.02);
  }
  .wc-items li span { font-weight: 700; flex-shrink: 0; }
  .wc-blue .wc-items li span { color: var(--blue); }
  .wc-green .wc-items li span { color: var(--green); }
  .wc-red .wc-items li span { color: var(--red); }
  .wc-rule {
    margin-top: 1rem; padding: 0.8rem 1rem; border-radius: 8px;
    font-size: 0.82rem; font-weight: 600; line-height: 1.5;
  }
  .wc-blue .wc-rule { background: var(--blue-glow); color: var(--blue); border: 1px solid rgba(59,158,255,0.2); }
  .wc-green .wc-rule { background: var(--green-glow); color: var(--green); border: 1px solid rgba(46,204,113,0.2); }
  .wc-red .wc-rule { background: var(--red-glow); color: var(--red); border: 1px solid rgba(231,76,60,0.2); }

  /* Quick table */
  .quick-table-wrap { margin-top: 3rem; overflow-x: auto; }
  .quick-table {
    width: 100%; border-collapse: collapse; font-size: 0.88rem;
  }
  .quick-table th {
    background: var(--surface); color: var(--text2); font-weight: 700;
    padding: 0.9rem 1.2rem; text-align: left; letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  .quick-table td { padding: 0.8rem 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .quick-table tr:last-child td { border-bottom: none; }
  .badge {
    display: inline-block; padding: 0.25rem 0.8rem; border-radius: 50px;
    font-size: 0.78rem; font-weight: 700;
  }
  .badge-blue { background: var(--blue-glow); color: var(--blue); border: 1px solid rgba(59,158,255,0.3); }
  .badge-green { background: var(--green-glow); color: var(--green); border: 1px solid rgba(46,204,113,0.3); }
  .badge-red { background: var(--red-glow); color: var(--red); border: 1px solid rgba(231,76,60,0.3); }

  /* ===== NEWS / STATS SECTION ===== */
  #news { background: var(--bg); }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.2rem; margin-bottom: 3rem; }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 1.5rem; text-align: center;
    transition: transform 0.3s;
  }
  .stat-card:hover { transform: translateY(-3px); }
  .stat-num { font-size: 2.5rem; font-weight: 900; margin-bottom: 0.3rem; }
  .stat-num.blue { color: var(--blue); }
  .stat-num.green { color: var(--green); }
  .stat-num.red { color: var(--red); }
  .stat-num.accent { color: var(--accent); }
  .stat-label { font-size: 0.82rem; color: var(--text2); line-height: 1.4; }
  .news-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem; }
  .news-link {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 1.3rem 1.5rem;
    text-decoration: none; color: inherit;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; transition: all 0.2s;
  }
  .news-link:hover { border-color: var(--blue); background: var(--blue-glow); }
  .news-link-text { font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .news-link-sub { font-size: 0.75rem; color: var(--text2); margin-top: 0.2rem; }
  .news-link-arr { color: var(--blue); font-size: 1.2rem; flex-shrink: 0; }
  .bar-chart { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 2rem; }
  .bar-row { display: flex; align-items: center; gap: 1rem; }
  .bar-label { font-size: 0.8rem; color: var(--text2); min-width: 130px; text-align: right; }
  .bar-track { flex: 1; background: rgba(255,255,255,0.05); border-radius: 4px; height: 14px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; animation: barGrow 1.2s ease both; }
  .bar-val { font-size: 0.8rem; font-weight: 700; min-width: 50px; }
  @keyframes barGrow { from { width: 0 !important; } }

  /* ===== HAZARDOUS ===== */
  #hazardous { background: var(--bg2); }
  .haz-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .haz-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 1.6rem; transition: border-color 0.3s;
  }
  .haz-card:hover { border-color: var(--red); }
  .haz-icon { font-size: 2.2rem; margin-bottom: 0.8rem; }
  .haz-card h3 { font-size: 1rem; font-weight: 800; color: var(--red); margin-bottom: 0.5rem; }
  .haz-card p { font-size: 0.82rem; color: var(--text2); line-height: 1.6; margin-bottom: 0.8rem; }
  .haz-where { font-size: 0.8rem; background: var(--red-glow); color: var(--red); border: 1px solid rgba(231,76,60,0.2); border-radius: 6px; padding: 0.5rem 0.8rem; }
  .methods-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; margin-top: 2.5rem; }
  .method-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 1.4rem; border-left: 3px solid var(--red);
  }
  .method-card h4 { font-size: 0.95rem; font-weight: 700; color: var(--red); margin-bottom: 0.5rem; }
  .method-card p { font-size: 0.82rem; color: var(--text2); line-height: 1.6; }
  .warning-box {
    background: var(--red-glow); border: 1px solid rgba(231,76,60,0.3);
    border-radius: 12px; padding: 1.4rem; margin-top: 2rem;
    display: flex; gap: 1rem; align-items: flex-start;
  }
  .warning-box .wi { font-size: 1.5rem; flex-shrink: 0; }
  .warning-box p { font-size: 0.85rem; color: var(--text2); line-height: 1.6; }
  .warning-box strong { color: var(--red); }

  /* ===== GAME SECTION ===== */
  #game { background: var(--bg); }
  #gameCanvas {
    border: 2px solid var(--border); border-radius: 12px;
    display: block; margin: 0 auto; cursor: crosshair;
    background: #0d0d18;
    image-rendering: pixelated;
    max-width: 100%;
  }
  .game-ui {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }
  #gameCanvas {
  width: 900px;
  height: 580px;
  }
  .game-stat {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.6rem 1.2rem; text-align: center;
  }
  .game-stat .gs-label { font-size: 0.7rem; color: var(--text2); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  .game-stat .gs-val { font-size: 1.4rem; font-weight: 900; }
  .game-stat .gs-val.score { color: var(--accent); }
  .game-stat .gs-val.lives { color: var(--red); }
  .game-stat .gs-val.level { color: var(--blue); }
  .game-controls {
    display: flex; gap: 0.8rem; justify-content: center; margin-top: 1rem; flex-wrap: wrap;
  }
  .btn-game {
    padding: 0.65rem 1.6rem; border-radius: 8px; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; border: none; transition: all 0.2s;
  }
  .btn-game-start { background: linear-gradient(135deg, var(--green-dark), var(--green)); color: white; }
  .btn-game-start:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-game-stop { background: var(--surface); color: var(--red); border: 1px solid var(--red); }
  .game-legend {
    display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;
    margin-top: 1.2rem; font-size: 0.82rem; color: var(--text2);
  }
  .legend-item { display: flex; align-items: center; gap: 0.4rem; }
  .legend-dot { width: 12px; height: 12px; border-radius: 3px; }

  /* ===== CONTACT ===== */
  #contact { background: var(--bg2); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  @media(max-width:680px){ .contact-grid { grid-template-columns: 1fr; } }
  .contact-info h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.8rem; }
  .contact-info p { color: var(--text2); font-size: 0.88rem; line-height: 1.7; margin-bottom: 1.2rem; }
  .contact-mail {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: var(--blue-glow); border: 1px solid var(--blue);
    color: var(--blue); border-radius: 8px; padding: 0.7rem 1.2rem;
    font-size: 0.88rem; font-weight: 600; text-decoration: none;
    transition: all 0.2s;
  }
  .contact-mail:hover { background: var(--blue); color: white; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group label { font-size: 0.78rem; font-weight: 700; color: var(--text2); letter-spacing: 0.5px; text-transform: uppercase; display: block; margin-bottom: 0.35rem; }
  .form-group input, .form-group textarea, .form-group select {
    width: 100%; background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); padding: 0.7rem 1rem; font-size: 0.88rem;
    font-family: inherit; outline: none; transition: border-color 0.2s;
  }
  .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--blue); }
  .form-group textarea { height: 120px; resize: vertical; }
  .form-group select option { background: var(--bg2); }
  .btn-send {
    background: linear-gradient(135deg, var(--blue), var(--blue-dark));
    color: white; border: none; padding: 0.8rem 2rem;
    border-radius: 8px; font-size: 0.92rem; font-weight: 700;
    cursor: pointer; align-self: flex-start; transition: opacity 0.2s;
  }
  .btn-send:hover { opacity: 0.88; }
  .form-success {
    background: var(--green-glow); border: 1px solid var(--green);
    color: var(--green); border-radius: 8px; padding: 0.9rem 1.2rem;
    font-size: 0.88rem; font-weight: 600; display: none;
  }

  /* ===== POPUP ===== */
  .popup-overlay {
    position: fixed; inset: 0; z-index: 2000;
    background: rgba(0,0,0,0.75); backdrop-filter: blur(8px);
    display: none; align-items: center; justify-content: center;
    padding: 1rem;
  }
  .popup-overlay.active { display: flex; }
  .popup-box {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 20px; padding: 2.5rem; max-width: 480px; width: 100%;
    position: relative; animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
  }
  .popup-close {
    position: absolute; top: 1rem; right: 1rem;
    background: rgba(255,255,255,0.06); border: none; color: var(--text2);
    width: 32px; height: 32px; border-radius: 50%; cursor: pointer;
    font-size: 1.1rem; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .popup-close:hover { background: var(--red-glow); color: var(--red); }
  .popup-box h2 { font-size: 1.4rem; font-weight: 900; margin-bottom: 0.5rem; }
  .popup-box p { font-size: 0.85rem; color: var(--text2); line-height: 1.7; margin-bottom: 1rem; }
  .popup-fact {
    background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem; margin-bottom: 0.8rem;
    font-size: 0.83rem; color: var(--text2); line-height: 1.6;
  }
  .popup-fact strong { color: var(--text); }

  /* ===== FOOTER ===== */
  footer {
    background: var(--surface); border-top: 1px solid var(--border);
    padding: 2.5rem 2rem; text-align: center;
    color: var(--text2); font-size: 0.82rem;
  }
  footer a { color: var(--blue); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  /* ===== ANIMS ===== */
  @keyframes fadeDown { from { opacity:0; transform: translateY(-20px); } to { opacity:1; transform: translateY(0); } }
  @keyframes fadeUp { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
  @keyframes popIn { from { opacity:0; transform: scale(0.85); } to { opacity:1; transform: scale(1); } }

  @media(max-width:600px){
    nav { padding: 0 1rem; }
    .nav-links { display: none; }
    .hero-title { font-size: 2.2rem; }
    section { padding: 3.5rem 1.2rem; }
  }
body {
  background: #040C1A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start; /* center биш */
  min-height: 100vh;
  font-family: 'Press Start 2P', 'Courier New', monospace;

  cursor: crosshair;   /* ← FIX */
  overflow-y: auto;    /* ← FIX */
}

#gameCanvas {
  display: block;
  margin-top: 40px; /* бага зай */
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">♻ ХОГ АНГИЛАХ</div>
  <div class="nav-links">
    <a href="#classification">Ангилал</a>
    <a href="#news">Мэдээлэл</a>
    <a href="#hazardous">Аюултай хог</a>
    <a href="#game">Тоглоом</a>
