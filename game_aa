function spawnWaste(){
  if(G.wastes.length >= MAXWASTES) return;
  const def = WASTE_DEFS[Math.floor(Math.random()*WASTE_DEFS.length)];
  const sz  = WSIZES[def.id];
  const pw  = sz.w*P, ph = sz.h*P;
  const margin = 55;
  // avoid middle area if bins are there
  let x = margin + Math.random()*(W-2*margin-pw);
  // keep x away from bins (bottom area not spawn area anyway)
  const yMin = HUD_H + 20;
  const yMax = GROUND_Y - ph - 10;
  const y = yMin + Math.random()*(yMax-yMin);
  G.wastes.push({ id:G.nid++, def, x, y, sz, spawnTime:Date.now() });
  sfxSpawn();
}

// ── Hit tests ─────────────────────────────────────────────────────
function wasteAt(mx,my){
  for(let i=G.wastes.length-1;i>=0;i--){
    const w=G.wastes[i];
    if(mx>=w.x && mx<=w.x+w.sz.w*P && my>=w.y && my<=w.y+w.sz.h*P) return i;
  }
  return -1;
}
function binAt(mx,my){
  for(let i=0;i<BINS.length;i++){
    const b=BINS[i];
    if(mx>=b.x && mx<=b.x+b.w && my>=b.y && my<=b.y+b.h) return i;
  }
  return -1;
}
function stopBtnHit(mx,my){ return mx>=8&&mx<=92&&my>=10&&my<=42; }
function startBtnHit(mx,my){ return mx>=W/2-120&&mx<=W/2+120&&my>=482&&my<=534; }
function infoBtnHit(mx,my){ return mx>=W-145&&mx<=W-5&&my>=H-60&&my<=H-15; }
function restartBtnHit(mx,my){ return mx>=W/2-145&&mx<=W/2-5&&my>=494&&my<=540; }
function goInfoBtnHit(mx,my){ return mx>=W/2+5&&mx<=W/2+145&&my>=494&&my<=540; }
function backBtnHit(mx,my){ return mx>=W/2-90&&mx<=W/2+90&&my>=H-60&&my<=H-12; }

// ── Input ──────────────────────────────────────────────────────────
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();

  const scaleX = canvas.width / r.width;
  const scaleY = canvas.height / r.height;

  G.mx = (e.clientX - r.left) * scaleX;
  G.my = (e.clientY - r.top) * scaleY;

  if (G.screen === 'playing' && G.dragging === null) {
    G.hover = wasteAt(G.mx, G.my);
  }
});

canvas.addEventListener('mousedown', e=>{
  const r=canvas.getBoundingClientRect();
  const mx=(e.clientX-r.left)*(W/r.width);
  const my=(e.clientY-r.top)*(H/r.height);
  try{ act(); }catch(ex){}

  if(G.screen==='title'){
    if(startBtnHit(mx,my)) startGame();
    if(infoBtnHit(mx,my)) G.screen='info';
    return;
  }
  if(G.screen==='gameover'){
    if(restartBtnHit(mx,my)) startGame();
    if(goInfoBtnHit(mx,my)) G.screen='info';
    return;
  }
  if(G.screen==='info'){
    if(backBtnHit(mx,my)) G.screen = G.gameOver ? 'gameover':'title';
    return;
  }
  if(G.screen==='playing'){
    if(stopBtnHit(mx,my)){ G.screen='title'; return; }
    const idx = wasteAt(mx,my);
    if(idx>=0){
      const w=G.wastes[idx];
      G.dragging = { idx, offX:mx-w.x, offY:my-w.y };
      G.hover=-1;
      sfxPickup();
    }
  }
});

canvas.addEventListener('mouseup', e=>{
  if(G.screen!=='playing' || G.dragging===null) return;
  const r=canvas.getBoundingClientRect();
  const mx=(e.clientX-r.left)*(W/r.width);
  const my=(e.clientY-r.top)*(H/r.height);

  const w = G.wastes[G.dragging.idx];
  if(!w){ G.dragging=null; return; }

  const cx = mx - G.dragging.offX + w.sz.w*P/2;
  const cy = my - G.dragging.offY + w.sz.h*P/2;
  const bi = binAt(cx, cy);

  if(bi>=0){
    const bin=BINS[bi];
    if(bin.type===w.def.bin){
      sfxCorrect();
      G.score += 10;
      G.correct++;
      fx(cx, BIN_Y-20, '+10', '#69F0AE');
      fx(cx, BIN_Y+10, '✓ ЗӨВЛӨВ!', '#A5D6A7');
      G.fact = w.def.fact;
      G.factTimer = 220;
      G.wastes.splice(G.dragging.idx, 1);
    } else {
      sfxWrong();
      G.lives--;
      G.wrong++;
      fx(cx, BIN_Y-20, '-1 ♥', '#FF5252');
      fx(cx, BIN_Y+10, '✗ БУРУУ!', '#EF9A9A');
      // put waste back on ground
      w.x = Math.max(10, Math.min(W-w.sz.w*P-10, mx-G.dragging.offX));
      w.y = GROUND_Y - w.sz.h*P - 4;
      if(G.lives<=0){ endGame('Амьд дуусав!'); G.dragging=null; return; }
    }
  } else {
    sfxDrop();
    w.x = Math.max(10, Math.min(W-w.sz.w*P-10, mx-G.dragging.offX));
    w.y = Math.max(HUD_H+5, Math.min(GROUND_Y - w.sz.h*P - 4, my-G.dragging.offY));
  }
  G.dragging=null;
});

// ── Effects ───────────────────────────────────────────────────────
function fx(x,y,text,color){
  G.effects.push({ x,y,text,color, life:70, vy:-1.2 });
}
function updateFx(){
  G.effects = G.effects.filter(e=>e.life>0);
  G.effects.forEach(e=>{ e.life--; e.y+=e.vy; });
  if(G.factTimer>0) G.factTimer--;
}
function drawFx(){
  G.effects.forEach(e=>{
    const a = e.life/70;
    ctx.globalAlpha=a;
    ctx.fillStyle=e.color;
    ctx.font=`bold ${P*2.2}px 'Press Start 2P',monospace`;
    ctx.textAlign='center';
    ctx.fillText(e.text, e.x, e.y);
  });
  ctx.globalAlpha=1;
}

// ── Game flow ─────────────────────────────────────────────────────
function startGame(){
  G.lives=3; G.score=0; G.correct=0; G.wrong=0;
  G.wastes=[]; G.dragging=null; G.effects=[];
  G.lastSpawn=Date.now()-4000;
  G.spawnInt=5000; G.gameOverReason='';
  G.fact=''; G.factTimer=0; G.hover=-1;
  G.screen='playing';
  G.gameOver=false;
  G.nid=0;
}
function endGame(reason){
  G.gameOver=true; G.screen='gameover';
  G.gameOverReason=reason; G.dragging=null;
}

