// ── Drawing: Crosshair ────────────────────────────────────────────
function drawCrosshair(){
  const {mx,my}=G, size=10, gap=4;

  ctx.strokeStyle='#FF1744';
  ctx.lineWidth=1.5;

  ctx.beginPath(); ctx.arc(mx,my,8,0,Math.PI*2); ctx.stroke();

  ctx.beginPath(); ctx.moveTo(mx,my-gap); ctx.lineTo(mx,my-size); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(mx,my+gap); ctx.lineTo(mx,my+size); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(mx-gap,my); ctx.lineTo(mx-size,my); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(mx+gap,my); ctx.lineTo(mx+size,my); ctx.stroke();
}

