const _winState = new Map();
function getBldgColor(bx){ return ['#0D1829','#121E30','#0F1A2B'][bx%3]; }

function drawCity(){
  const t=Date.now()/2500;
  BLDG.forEach((b,bi)=>{
    const by=GROUND_Y-b.h;
    ctx.fillStyle=getBldgColor(bi);
    ctx.fillRect(b.x,by,b.w,b.h);
    // pixel scanlines
    ctx.fillStyle='rgba(0,0,0,0.25)';
    for(let gy=0;gy<b.h;gy+=8) ctx.fillRect(b.x,by+gy,b.w,1);
    // roof detail
    ctx.fillStyle='rgba(255,255,255,0.06)';
    ctx.fillRect(b.x,by,b.w,3);
    // windows
    b.win.forEach(([wx,wy])=>{
      const key=`${bi}_${wx}_${wy}`;
      if(!_winState.has(key)) _winState.set(key,Math.random());
      const seed=_winState.get(key);
      const lit = Math.sin(t+seed*10) > -0.3;
      ctx.fillStyle = lit ? '#FFD54F' : '#081220';
      ctx.fillRect(b.x+wx, by+wy, 13, 10);
      if(lit){
        ctx.fillStyle='rgba(255,213,79,0.25)';
        ctx.fillRect(b.x+wx-2,by+wy-2,17,14);
      }
    });
  });
}

// ── Drawing: Bins ────────────────────────────────────────────────
function drawBins(){
  BINS.forEach((b,i)=>{
    const {x,y,w,h}=b;

    // glow
    const rg=ctx.createRadialGradient(x+w/2,y+h/2,10,x+w/2,y+h/2,w*0.9);
    rg.addColorStop(0,b.glow);
    rg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=rg; ctx.fillRect(x-20,y-20,w+40,h+40);

    // shadow
    ctx.fillStyle='rgba(0,0,0,0.5)'; ctx.fillRect(x+5,y+5,w,h);

    // body
    ctx.fillStyle=b.dark; ctx.fillRect(x,y,w,h);
    ctx.fillStyle=b.mid;  ctx.fillRect(x+3,y+3,w-6,h-6);

    // horizontal texture lines
    for(let ly=y+6;ly<y+h-3;ly+=14){
      ctx.fillStyle='rgba(0,0,0,0.2)'; ctx.fillRect(x+3,ly,w-6,2);
    }

    // highlight side
    ctx.fillStyle='rgba(255,255,255,0.07)';
    ctx.fillRect(x+3,y+3,6,h-6);

    // lid
    ctx.fillStyle=b.lid; ctx.fillRect(x,y,w,26);
    ctx.fillStyle=b.mid; ctx.fillRect(x+3,y+4,w-6,18);

    // slot
    ctx.fillStyle=b.slot; ctx.fillRect(x+w/2-22,y+7,44,12);
    // slot shine
    ctx.fillStyle='rgba(255,255,255,0.08)'; ctx.fillRect(x+w/2-20,y+8,44,4);

    // pixel border
    ctx.fillStyle=b.light;
    ctx.fillRect(x,y,2,h);
    ctx.fillRect(x+w-2,y,2,h);
    ctx.fillRect(x,y,w,2);
    ctx.fillRect(x,y+h-2,w,2);

    // icon
    drawBinIcon(b, x+w/2, y+60);

    // label
    ctx.textAlign='center';
    ctx.font=`bold ${P*1.7}px 'Press Start 2P',monospace`;
    ctx.fillStyle='rgba(0,0,0,0.8)';
    ctx.fillText(b.label, x+w/2+1, y+h-12+1);
    ctx.fillStyle='#FFFFFF';
    ctx.fillText(b.label, Math.round(x+w/2), Math.round(y+h-12));
  });
}
function drawText(txt, x, y){
  ctx.fillText(txt, Math.round(x), Math.round(y));
}
function drawBinIcon(b,cx,cy){
  const c=b.light;
  if(b.type===RECYCLE){
    ctx.fillStyle=c;
    // simplified recycle arrows (3 bent arrows pixel-art)
    [[0,-16,20,4],[10,8,-12,16],[-10,8,-8,-20]].forEach(([ax,ay,bx,by])=>{
      ctx.fillRect(cx+ax-2,cy+ay,8,4);
      ctx.fillRect(cx+ax,cy+ay,4,8);
    });
    ctx.fillStyle=b.light;
    ctx.strokeStyle=b.light; ctx.lineWidth=3;
    // draw proper recycle symbol
    ctx.beginPath();
    ctx.arc(cx,cy,14,0,Math.PI*2*0.33);
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(cx,cy,14,Math.PI*2/3,Math.PI*4/3);
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(cx,cy,14,Math.PI*4/3,Math.PI*2);
    ctx.stroke();
  } else if(b.type===GENERAL){
    ctx.fillStyle=c;
    ctx.fillRect(cx-13,cy-8,26,20);
    ctx.fillRect(cx-16,cy-14,32,8);
    ctx.fillRect(cx-9,cy-18,18,6);
    ctx.fillStyle='rgba(0,0,0,0.3)';
    ctx.fillRect(cx-7,cy-8,5,20);
    ctx.fillRect(cx+2,cy-8,5,20);
  } else {
    // hazard triangle pixel
    ctx.fillStyle='#FFEB3B';
    ctx.beginPath();
    ctx.moveTo(cx,cy-18); ctx.lineTo(cx+18,cy+12); ctx.lineTo(cx-18,cy+12);
    ctx.closePath(); ctx.fill();
    ctx.fillStyle='#212121';
    ctx.font=`bold ${P*3}px Arial`;
    ctx.textAlign='center';
    ctx.fillText('!',cx,cy+10);
  }
}

// ── Drawing: Wastes ───────────────────────────────────────────────
function drawWastes(){
  const t=Date.now()/1000;
  G.wastes.forEach((w,i)=>{
    if(G.dragging && G.dragging.idx===i) return;
    const age=(Date.now()-w.spawnTime)/1000;
    const hov=(G.hover===i);

    // age warning flash
    if(age>12){
      const fl=Math.sin(Date.now()/250)>0;
      if(fl){ ctx.fillStyle='rgba(255,30,30,0.18)';
        ctx.fillRect(w.x-5,w.y-5,w.sz.w*P+10,w.sz.h*P+10); }
    }

    // shadow
    ctx.fillStyle='rgba(0,0,0,0.35)';
    ctx.fillRect(w.x+4,w.y+5,w.sz.w*P,w.sz.h*P);

    // draw pixel art
    if(ART[w.def.id]) ART[w.def.id](w.x,w.y);

    // hover outline
    if(hov){
      ctx.strokeStyle='#FFD700'; ctx.lineWidth=2.5;
      ctx.strokeRect(w.x-4,w.y-4,w.sz.w*P+8,w.sz.h*P+8);
      drawTooltip(w.def.name, w.x+w.sz.w*P/2, w.y-14);
    }
  });

  // Draw dragged item
  if(G.dragging!==null){
    const w=G.wastes[G.dragging.idx];
    if(w){
      const dx=G.mx-G.dragging.offX, dy=G.my-G.dragging.offY;
      ctx.fillStyle='rgba(0,0,0,0.4)';
      ctx.fillRect(dx+6,dy+7,w.sz.w*P,w.sz.h*P);
      if(ART[w.def.id]) ART[w.def.id](dx,dy);
      drawTooltip(w.def.name, dx+w.sz.w*P/2, dy-14);

      // highlight matching bin
      const cx=dx+w.sz.w*P/2, cy=dy+w.sz.h*P/2;
      BINS.forEach(b=>{
        if(b.type===w.def.bin){
          ctx.strokeStyle=b.light; ctx.lineWidth=3;
          ctx.setLineDash([6,4]);
          ctx.strokeRect(b.x-3,b.y-3,b.w+6,b.h+6);
          ctx.setLineDash([]);
        }
      });
    }
  }
}

function drawTooltip(txt,cx,cy){
  ctx.font=`${P*1.5}px 'Press Start 2P',monospace`;
  const tw=ctx.measureText(txt).width;
  const tx=Math.max(5,Math.min(W-tw-14,cx-tw/2-7));
  const ty=Math.max(HUD_H+5,cy-26);
  ctx.fillStyle='rgba(5,15,35,0.92)'; ctx.fillRect(tx,ty,tw+14,24);
  ctx.fillStyle='#D4A017'; ctx.fillRect(tx,ty,tw+14,2);
  ctx.fillStyle='#FFFFFF'; ctx.textAlign='left';
  ctx.fillText(txt,tx+7,ty+17);
  ctx.textAlign='center';
}

