// ── Main loop ─────────────────────────────────────────────────────
function loop(){
  ctx.clearRect(0,0,W,H);
  drawBg();

  if(G.screen==='title'){
    drawTitleScreen();
  } else if(G.screen==='playing'){
    // spawn logic
    const now=Date.now();
    if(now-G.lastSpawn > G.spawnInt){
      G.lastSpawn=now;
      if(G.wastes.length < MAXWASTES) spawnWaste();
      else endGame('Хог хэтэрхий хуримтлагдлаа!');
      G.spawnInt = Math.max(2200, G.spawnInt - 80);
    }
    drawBins();
    drawWastes();
    updateFx(); drawFx();
    drawHUD();
  } else if(G.screen==='gameover'){
    drawGameOver();
  } else if(G.screen==='info'){
    drawInfo();
  }

  drawCrosshair();
  requestAnimationFrame(loop);
}
  requestAnimationFrame(loop);
</script>
