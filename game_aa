function drawBg(){
  // Sky
  const sk = ctx.createLinearGradient(0,HUD_H,0,GROUND_Y);
  sk.addColorStop(0,'#060D1F');
  sk.addColorStop(0.4,'#0F2545');
  sk.addColorStop(1,'#1A3F75');
  ctx.fillStyle=sk; ctx.fillRect(0,HUD_H,W,GROUND_Y-HUD_H);

  // Stars twinkle
  const t = Date.now()/1000;
  STARS.forEach(([sx,sy,sr])=>{
    const bright = 0.4+0.6*Math.abs(Math.sin(t*0.7+sx));
    ctx.globalAlpha = bright;
    ctx.fillStyle = '#E8F4FD';
    ctx.fillRect(sx,sy,sr,sr);
  });
  ctx.globalAlpha=1;

  // Moon
  drawMoon(820, 85);

  // City buildings (silhouette)
  drawCity();

  // Ground strip
  ctx.fillStyle='#1C1208';
  ctx.fillRect(0,GROUND_Y,W,H-GROUND_Y);
  ctx.fillStyle='#CEC9B8'; // snow
  ctx.fillRect(0,GROUND_Y,W,9);
  ctx.fillStyle='#A9A394';
  ctx.fillRect(0,GROUND_Y+9,W,5);
  // road lines
  ctx.fillStyle='#5A5040';
  for(let rx=90;rx<W;rx+=130) ctx.fillRect(rx,GROUND_Y+20,70,4);
}

